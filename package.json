{
  "name": "lms-portal",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm run dev --workspace @lms/api\" \"npm run dev --workspace @lms/web\"",
    "dev:api": "npm run dev --workspace @lms/api",
    "dev:web": "npm run dev --workspace @lms/web",
    "test": "npm run test --workspace @lms/api",
    "lint": "npm run lint --workspace @lms/web",
    "build": "npm run build --workspace @lms/web",
    "start": "npm run start --workspace @lms/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
